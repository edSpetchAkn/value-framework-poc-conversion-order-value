# Copy this file to .env and set values for your PIM instance.

# Set to true to enable verbose console.debug output at each calculation step.
VITE_DEBUG_MODE=false

# The channel code to prefer for the completeness-per-channel metric.
# The metric will fall back to the first channel found in the data if this
# channel code does not appear in any product's completeness entries.
VITE_DEFAULT_CHANNEL=ecommerce

# Number of products to fetch per page. Akeneo REST API maximum is 100.
VITE_PRODUCTS_PAGE_SIZE=100
